# Shah-Stream configuration
# -------------------------
# Copy this file to ".env" (in the project root) and adjust the values.
# All keys are optional; the defaults shown below are used when a key is absent.
# Booleans accept: true / 1 / yes / on  (anything else is treated as false).

# WebSocket URL of the sync server used for "watch together" sessions.
SHAH_SERVER_URL=wss://shah-stream-sync-server.onrender.com/

# Default room name to join when connecting (or auto-connecting).
SHAH_DEFAULT_ROOM=lobby

# Display name broadcast to peers as the message sender.
SHAH_CLIENT_NAME=guest

# When true, connect to SHAH_SERVER_URL / SHAH_DEFAULT_ROOM automatically on startup.
SHAH_AUTO_CONNECT=false

# Root logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
SHAH_LOG_LEVEL=INFO

# When true, also write rotating log files to <project-root>/logs/shah_stream.log.
SHAH_LOG_TO_FILE=true
